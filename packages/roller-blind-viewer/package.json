{
  "name": "@diloytd/roller-blind-viewer",
  "version": "0.0.1",
  "description": "React-компоненты превью рулонной шторы (React Three Fiber)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
